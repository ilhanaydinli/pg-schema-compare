{
    "name": "pg-schema-compare",
    "version": "1.0.2",
    "description": "Compare two PostgreSQL database schemas structurally, ignoring naming differences",
    "type": "module",
    "bin": {
        "pg-schema-compare": "./dist/bin/cli.js"
    },
    "main": "./dist/src/index.js",
    "types": "./dist/src/index.d.ts",
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "bun run tsc",
        "dev": "bun run bin/cli.ts",
        "check": "bun run check:types && bun run check:lint && bun run check:format && bun run knip",
        "check:types": "bunx --bun tsc --noEmit",
        "check:lint": "bunx --bun eslint src tests bin",
        "check:format": "bunx --bun prettier --check '{src,tests,bin}/**/*.ts'",
        "fix": "bun run fix:lint && bun run fix:format && bun run fix:knip",
        "fix:lint": "bunx --bun eslint src tests bin --fix",
        "fix:format": "bunx --bun prettier --write '{src,tests,bin}/**/*.ts'",
        "fix:knip": "bunx --bun knip --fix",
        "test": "bun test",
        "knip": "knip-bun",
        "prepublishOnly": "bun run build"
    },
    "keywords": [
        "postgresql",
        "schema",
        "diff",
        "compare",
        "migration",
        "database"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/ilhanaydinli/pg-schema-compare"
    },
    "license": "MIT",
    "dependencies": {
        "chalk": "^5.4.0",
        "cli-table3": "^0.6.5",
        "commander": "^13.0.0",
        "pg": "^8.13.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "@types/bun": "latest",
        "@types/pg": "^8.11.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.0.0",
        "eslint-plugin-prettier": "^5.0.0",
        "eslint-plugin-simple-import-sort": "^12.0.0",
        "globals": "^16.0.0",
        "knip": "^5.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.0.0"
    }
}
